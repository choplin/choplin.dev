---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
// Strip a leading non-default locale segment (e.g. /ja) so active-state
// matching works the same on English and Japanese routes.
const stripLocale = (p: string) => p.replace(/^\/ja(?=\/|$)/, '') || '/';
const pathname = stripLocale(Astro.url.pathname.replace(import.meta.env.BASE_URL, ''));
const target = stripLocale(String(href));
const subpath = pathname.match(/[^\/]+/g);
const isActive = target === pathname || target === '/' + (subpath?.[0] || '');
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
