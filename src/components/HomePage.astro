---
import { SITE_TITLE } from '../consts';
import { type Locale, UI, localePath, otherLocale } from '../i18n';
import BaseHead from './BaseHead.astro';
import Footer from './Footer.astro';
import Header from './Header.astro';
import PostList from './PostList.astro';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = UI[locale];
const switchHref = localePath(otherLocale(locale), '/');
---

<!doctype html>
<html lang={locale}>
	<head>
		<BaseHead title={SITE_TITLE} description={t.site.description} />
		<style>
			.intro {
				margin-bottom: 2.5rem;
			}
			.intro h1 {
				margin: 0 0 0.2em;
			}
			.intro p {
				margin: 0.2em 0;
				color: rgb(var(--gray));
			}
			.all-posts {
				margin-top: 2rem;
				text-align: right;
			}
		</style>
	</head>
	<body>
		<Header locale={locale} switchHref={switchHref} />
		<main>
			<section class="intro">
				<h1>{SITE_TITLE}</h1>
				<p>{t.home.role}</p>
				<p>{t.home.intro}</p>
			</section>
			<PostList locale={locale} limit={5} />
			<p class="all-posts">
				<a href={localePath(locale, '/blog')}>{t.home.allPosts}</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
