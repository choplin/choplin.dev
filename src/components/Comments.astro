---
import { GISCUS } from '../consts';

interface Props {
	/** Immutable per-post key (frontmatter `commentId`) — the giscus discussion term. */
	term: string;
	/** giscus UI language; defaults to the configured one. Pass the post locale. */
	lang?: string;
}

const { term, lang = GISCUS.lang } = Astro.props;
const enabled = GISCUS.enabled && !!term;
---

{enabled && <section id="giscus-container" class="comments" aria-label="Comments" />}

{
	enabled && (
		<script
			define:vars={{
				repo: GISCUS.repo,
				repoId: GISCUS.repoId,
				category: GISCUS.category,
				categoryId: GISCUS.categoryId,
				reactionsEnabled: GISCUS.reactionsEnabled,
				emitMetadata: GISCUS.emitMetadata,
				inputPosition: GISCUS.inputPosition,
				theme: GISCUS.theme,
				lang,
				term,
			}}
		>
			(function () {
				const container = document.getElementById('giscus-container');
				if (!container) return;
				const darkQuery = window.matchMedia('(prefers-color-scheme: dark)');
				function resolveTheme() {
					// 'noborder' -> borderless theme that follows the OS light/dark setting.
					if (theme === 'noborder')
						return darkQuery.matches ? 'noborder_dark' : 'noborder_light';
					// A leading-'/' path is a same-origin custom CSS theme; giscus needs it absolute.
					return theme.charAt(0) === '/' ? location.origin + theme : theme;
				}
				const s = document.createElement('script');
				s.src = 'https://giscus.app/client.js';
				s.async = true;
				s.crossOrigin = 'anonymous';
				const attrs = {
					'data-repo': repo,
					'data-repo-id': repoId,
					'data-category': category,
					'data-category-id': categoryId,
					'data-mapping': 'specific',
					'data-term': term,
					'data-strict': '1',
					'data-reactions-enabled': reactionsEnabled,
					'data-emit-metadata': emitMetadata,
					'data-input-position': inputPosition,
					'data-theme': resolveTheme(),
					'data-lang': lang,
					'data-loading': 'lazy',
				};
				Object.keys(attrs).forEach(function (k) {
					s.setAttribute(k, attrs[k]);
				});
				container.appendChild(s);
				// Only when auto-following the OS ('noborder'): re-sync giscus on scheme change.
				if (theme === 'noborder') {
					darkQuery.addEventListener('change', function () {
						const frame = container.querySelector('iframe.giscus-frame');
						if (frame)
							frame.contentWindow.postMessage(
								{ giscus: { setConfig: { theme: resolveTheme() } } },
								'https://giscus.app',
							);
					});
				}
			})();
		</script>
	)
}

<style>
	.comments {
		display: block;
		width: 720px;
		max-width: calc(100% - 2em);
		margin: 3em auto 0;
		padding: 1.5em 1em 0;
		border-top: 1px solid rgb(var(--gray-light));
	}
</style>
